---
import "../styles/global.css";
const { title = "Karen Dettmar", description } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300..700&family=Source+Serif+4:ital,opsz,wght@0,8..60,300..900;1,8..60,300..900&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        --bg: #fbf6f0;
        --fg: #2f3a4a;
        --fg-muted: #7a8a9a;
      }
      html.dark {
        --bg: #2f3a4a;
        --fg: #fbf6f0;
        --fg-muted: #c0cad4;
      }
      body {
        font-family: 'Inter', system-ui, sans-serif;
        background-color: var(--bg);
        color: var(--fg);
        transition: background-color 0.2s, color 0.2s;
      }
      .site-name,
      h1, h2, h3, h4, h5, h6 {
        font-family: 'Source Serif 4', Georgia, serif;
      }
      .site-header {
        background-color: color-mix(in srgb, var(--bg) 90%, transparent);
        border-color: color-mix(in srgb, var(--fg) 10%, transparent);
      }
      #theme-toggle {
        color: var(--fg-muted);
        transition: color 0.2s;
      }
      #theme-toggle:hover {
        color: var(--fg);
      }

      /* Dark mode overrides for hardcoded Tailwind zinc utilities */
      html.dark .text-zinc-900,
      html.dark .text-zinc-800,
      html.dark .text-zinc-700 { color: var(--fg); }

      html.dark .text-zinc-600,
      html.dark .text-zinc-500,
      html.dark .text-zinc-400 { color: var(--fg-muted); }

      html.dark .bg-white { background-color: color-mix(in srgb, var(--fg) 8%, var(--bg)); }
      html.dark .bg-zinc-100 { background-color: color-mix(in srgb, var(--fg) 12%, var(--bg)); }
      html.dark .bg-zinc-900 { background-color: var(--fg); }
      html.dark .hover\:bg-zinc-800:hover,
      html.dark .hover\:bg-zinc-700:hover { background-color: color-mix(in srgb, var(--fg) 85%, var(--bg)); }
      html.dark .text-white { color: var(--bg); }

      html.dark .border-zinc-100,
      html.dark .border-zinc-200,
      html.dark .border-zinc-300 { border-color: color-mix(in srgb, var(--fg) 18%, var(--bg)); }
      html.dark .hover\:border-zinc-300:hover { border-color: color-mix(in srgb, var(--fg) 30%, var(--bg)); }

      html.dark .hover\:bg-zinc-50:hover { background-color: color-mix(in srgb, var(--fg) 6%, var(--bg)); }
      html.dark .shadow-sm { box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.3); }
    </style>
    <!-- init theme before paint to avoid flash -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem("theme");
        if (saved === "dark" || (!saved && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body class="min-h-screen antialiased">
    <header class="site-header sticky top-0 z-10 border-b backdrop-blur-sm">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
        <a href="/" class="site-name text-sm font-semibold tracking-tight transition-opacity hover:opacity-60" style="color: var(--fg)">
          Karen Dettmar
        </a>
        <nav class="flex items-center gap-6 text-sm" style="color: var(--fg-muted)">
          <a class="transition-colors hover:text-zinc-900 dark:hover:text-white" href="/demos">Demos</a>
          <a class="transition-colors hover:text-zinc-900 dark:hover:text-white" href="/about">About</a>
          <a class="transition-colors hover:text-zinc-900 dark:hover:text-white" href="/karen-dettmar-resume.pdf">Resume</a>
          <button
            id="theme-toggle"
            aria-label="Toggle light/dark mode"
            class="text-base leading-none"
          >
            <span id="theme-icon-light" class="hidden">&#9790;</span>
            <span id="theme-icon-dark">&#9788;</span>
          </button>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-6 py-16">
      <slot />
    </main>

    <footer class="border-t" style="border-color: color-mix(in srgb, var(--fg) 12%, transparent)">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-8 text-xs" style="color: var(--fg-muted)">
        <span>© 2025 Karen Dettmar</span>
        <div class="flex gap-5">
          <a class="transition-colors hover:opacity-100" href="mailto:karen.dettmar@gmail.com">Email</a>
          <a class="transition-colors hover:opacity-100" href="https://linkedin.com/in/kdettmar" target="_blank">LinkedIn</a>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById("theme-toggle");
      const iconLight = document.getElementById("theme-icon-light");
      const iconDark = document.getElementById("theme-icon-dark");

      function updateIcon() {
        const isDark = document.documentElement.classList.contains("dark");
        iconLight?.classList.toggle("hidden", !isDark);
        iconDark?.classList.toggle("hidden", isDark);
      }

      updateIcon();

      toggle?.addEventListener("click", () => {
        const isDark = document.documentElement.classList.toggle("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
        updateIcon();
      });
    </script>
  </body>
</html>
