---
import SiteLayout from "../layouts/Layout.astro";
---

<SiteLayout title="Karen Dettmar — Creative Technologist" description="Applied AI demos for creative communities and cultural institutions.">
  <section class="flex flex-col gap-20">

    <div class="max-w-2xl">
      <p class="text-xs font-semibold uppercase tracking-widest text-zinc-400">Creative Technologist</p>
      <h1 class="mt-4 text-5xl font-semibold tracking-tight leading-[1.1]">
        Building tools<br />people actually use.
      </h1>
      <p class="mt-5 text-lg text-zinc-500 leading-relaxed">
        I demo, prototype, and workshop applied AI for creative communities
        and cultural institutions — translating APIs into things that feel human.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/demos" class="inline-flex items-center rounded-xl bg-zinc-900 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-zinc-700">
          View demos
        </a>
        <a href="/about" class="inline-flex items-center rounded-xl border border-zinc-200 px-5 py-2.5 text-sm font-semibold text-zinc-700 transition-colors hover:bg-zinc-50 hover:border-zinc-300">
          About me
        </a>
      </div>
    </div>

    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-zinc-400 mb-6">Featured work</p>
      <div class="grid gap-4 md:grid-cols-2">
        <a href="/demos/museum-label-generator" class="group rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm transition-all hover:border-zinc-300 hover:shadow-md">
          <div class="flex items-start justify-between gap-4">
            <h2 class="text-base font-semibold">Museum Label Generator</h2>
            <span class="shrink-0 rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-medium text-emerald-700">Live</span>
          </div>
          <p class="mt-2 text-sm text-zinc-500 leading-6">
            Draft wall labels, kids labels, audio scripts, alt text, and curator notes from source text.
          </p>
          <div class="mt-5 flex items-center gap-1.5 text-sm font-medium text-zinc-900 transition-all group-hover:gap-2.5">
            Open demo <span>→</span>
          </div>
        </a>

        <div class="rounded-2xl border border-dashed border-zinc-200 p-6">
          <p class="text-xs font-semibold uppercase tracking-widest text-zinc-400 mb-4">Coming next</p>
          <ul class="space-y-2.5 text-sm text-zinc-500">
            <li>Creative Process Companion</li>
            <li>Prompt Lab (workshop mode)</li>
          </ul>
        </div>
      </div>
    </div>

  </section>
</SiteLayout>
