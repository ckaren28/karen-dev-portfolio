---
import SiteLayout from "../../layouts/Layout.astro";

const demos = [
  {
    title: "Museum Label Generator",
    desc: "Draft wall labels, extended labels, kids labels, audio scripts, alt text, and curator notes from source text.",
    href: "/demos/museum-label-generator",
    tags: ["Museums", "Workshop"],
    status: "Live",
  },
  {
    title: "Creative Process Companion",
    desc: "Artist-forward ideation: three directions, constraints, materials/techniques, a mini plan, and critique questions.",
    href: "/demos/creative-process-companion",
    tags: ["Artists", "Workshop"],
    status: "Live",
  },
  {
    title: "Prompt Lab",
    desc: "Compare prompting strategies side-by-side (basic vs structured vs grounded) to teach practical LLM usage.",
    href: "/demos/prompt-lab",
    tags: ["Museums", "Workshop"],
    status: "Coming soon",
  },
];
---

<SiteLayout title="Demos — Karen Dettmar" description="Applied AI demos for creative communities and cultural institutions.">
  <header class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div>
      <h1 class="text-3xl font-semibold tracking-tight">Demos</h1>
      <p class="mt-2 max-w-2xl text-zinc-600 leading-7">
        Applied AI prototypes built for workshops, partner trainings, and real creative workflows.
      </p>
    </div>

    <div class="flex gap-3">
      <a
        href="/karen-dettmar-resume.pdf"
        target="_blank"
        class="rounded-xl border border-zinc-200 px-4 py-2 text-sm font-semibold text-zinc-800 hover:border-zinc-300 hover:bg-zinc-50"
      >
        Resume
      </a>
      <a
        href="/about"
        class="rounded-xl bg-zinc-900 px-4 py-2 text-sm font-semibold text-white hover:bg-zinc-800"
      >
        About
      </a>
    </div>
  </header>

  <!-- Controls -->
  <section class="mt-10 rounded-2xl border border-zinc-200 p-4 md:p-5">
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <div class="flex flex-wrap gap-2">
        <button data-chip="All" class="chip chip--active">All</button>
        <button data-chip="Museums" class="chip">Museums</button>
        <button data-chip="Artists" class="chip">Artists</button>
        <button data-chip="Workshop" class="chip">Workshop</button>
      </div>

      <div class="flex items-center gap-3">
        <div class="relative w-full md:w-[320px]">
          <input
            id="demo-search"
            class="w-full rounded-xl border border-zinc-200 px-3 py-2 pr-10 text-sm outline-none focus:border-zinc-400"
            placeholder="Search demos…"
            autocomplete="off"
          />
          <div class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-zinc-400">
            ⌘K
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cards -->
  <section class="mt-8">
    <div id="demo-grid" class="grid gap-6 md:grid-cols-2">
      {demos.map((d) => (
        <article
          class="demo-card group rounded-2xl border border-zinc-200 p-6 shadow-sm transition hover:border-zinc-300 hover:shadow"
          data-title={d.title.toLowerCase()}
          data-desc={d.desc.toLowerCase()}
          data-tags={d.tags.join(",")}
          data-status={d.status}
        >
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="text-lg font-semibold tracking-tight">{d.title}</h2>
              <p class="mt-2 text-sm leading-6 text-zinc-600">{d.desc}</p>
            </div>

            <span class={d.status === "Live" ? "badge badge--live" : "badge badge--soon"}>
              {d.status}
            </span>
          </div>

          <div class="mt-4 flex flex-wrap gap-2">
            {d.tags.map((t) => (
              <span class="tag">{t}</span>
            ))}
          </div>

          <div class="mt-6 flex items-center justify-between">
            {d.status === "Live" && (
              <a
                href={d.href}
                class="inline-flex items-center gap-2 rounded-xl bg-zinc-900 px-4 py-2 text-sm font-semibold text-white hover:bg-zinc-800"
              >
                Open <span class="transition group-hover:translate-x-0.5">→</span>
              </a>
            )}

            {d.status === "Live" && (
              <a
                href={d.href}
                class="text-sm font-semibold text-zinc-700 underline hover:text-zinc-900"
              >
                Read the approach
              </a>
            )}
          </div>
        </article>
      ))}
    </div>

    <p id="demo-empty" class="mt-8 hidden text-sm text-zinc-600">
      No demos match that filter. Try a different tag or search term.
    </p>
  </section>

  <!-- Tailwind component styles (kept local for convenience) -->
  <style>
    @reference "tailwindcss";
    .chip {
      @apply rounded-full border border-zinc-200 bg-white px-3 py-1 text-xs font-semibold text-zinc-700 hover:border-zinc-300 hover:text-zinc-900;
    }
    .chip--active {
      @apply border-zinc-900 text-zinc-900;
    }
    .tag {
      @apply rounded-full bg-zinc-100 px-3 py-1 text-xs text-zinc-700;
    }
    .badge {
      @apply shrink-0 rounded-full px-3 py-1 text-xs font-semibold;
    }
    .badge--live {
      @apply bg-emerald-50 text-emerald-700 border border-emerald-200;
    }
    .badge--soon {
      @apply bg-amber-50 text-amber-700 border border-amber-200;
    }
  </style>

  <!-- Client-side filtering/search (no framework) -->
  <script>
  (() => {
    const empty = document.getElementById("demo-empty");
    const search = document.getElementById("demo-search") as HTMLInputElement | null;
    const chips = Array.from(document.querySelectorAll<HTMLButtonElement>("button[data-chip]"));
    const cards = Array.from(document.querySelectorAll<HTMLElement>(".demo-card"));

    let activeChip = "All";

    const normalize = (s: string) => (s || "").toLowerCase().trim();

    function setActiveChip(name: string) {
      activeChip = name;
      chips.forEach((c) => c.classList.toggle("chip--active", c.dataset.chip === name));
      apply();
    }

    function matchesChip(card: HTMLElement) {
      if (activeChip === "All") return true;
      const tags = card.dataset.tags || "";
      return tags.split(",").map((t) => t.trim()).includes(activeChip);
    }

    function matchesSearch(card: HTMLElement) {
      if (!search) return true;
      const q = normalize(search.value);
      if (!q) return true;
      const hay = `${card.dataset.title} ${card.dataset.desc} ${(card.dataset.tags || "").toLowerCase()} ${(card.dataset.status || "").toLowerCase()}`;
      return hay.includes(q);
    }

    function apply() {
      let shown = 0;
      cards.forEach((card) => {
        const ok = matchesChip(card) && matchesSearch(card);
        card.classList.toggle("hidden", !ok);
        if (ok) shown++;
      });
      empty?.classList.toggle("hidden", shown !== 0);
    }

    chips.forEach((chip) => chip.addEventListener("click", () => setActiveChip(chip.dataset.chip ?? "All")));

    // Cmd+K focuses search (nice touch)
    document.addEventListener("keydown", (e) => {
      const isMac = navigator.platform.toLowerCase().includes("mac");
      if ((isMac && e.metaKey && e.key.toLowerCase() === "k") || (!isMac && e.ctrlKey && e.key.toLowerCase() === "k")) {
        e.preventDefault();
        search?.focus();
      }
    });

    search?.addEventListener("input", apply);

    // initial
    setActiveChip("All");
  })();
  </script>
</SiteLayout>
