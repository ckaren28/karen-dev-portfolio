---
import SiteLayout from "../../layouts/Layout.astro";
// @ts-ignore - Astro language server generates a conflicting local declaration for React component tags
import MuseumLabelGenerator from "../../components/MuseumLabelGenerator.tsx";
---

<SiteLayout title="Museum Label Generator — Karen Dettmar" description="Workshop-ready museum label drafting demo.">
  <div class="flex flex-col gap-3">
    <p class="text-sm text-zinc-600">
      <a class="underline hover:text-zinc-900" href="/demos">Demos</a> / Museum Label Generator
    </p>
    <h1 class="text-3xl font-semibold tracking-tight">Museum Label Generator</h1>
    <p class="max-w-3xl text-zinc-600 leading-7">
      Draft wall labels, extended labels, kids labels, audio scripts, alt text, and curator notes from a source description.
      Built to support human editorial control.
    </p>
  </div>

  <div class="mt-8 grid gap-8 lg:grid-cols-2">
    <!-- FORM -->
    <section class="rounded-2xl border border-zinc-200 p-6 shadow-sm">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h2 class="text-lg font-semibold">Artwork info</h2>
          <p class="mt-1 text-sm text-zinc-600">
            Paste a short source description (2–6 sentences works best).
          </p>
        </div>
        <label class="flex items-center gap-2 text-sm text-zinc-700">
          <input id="mlg-workshop" type="checkbox" class="h-4 w-4" />
          Workshop mode
        </label>
      </div>

      <div id="mlg-presets" class="mt-4 hidden">
        <div class="text-xs font-semibold text-zinc-700">Example inputs</div>
        <div class="mt-2 flex flex-wrap gap-2">
          <button data-preset="abstract" type="button" class="rounded-full border border-zinc-200 bg-white px-3 py-1 text-xs text-zinc-700 hover:border-zinc-300 hover:text-zinc-900">
            Abstract painting (accessibility + tone)
          </button>
          <button data-preset="provenance" type="button" class="rounded-full border border-zinc-200 bg-white px-3 py-1 text-xs text-zinc-700 hover:border-zinc-300 hover:text-zinc-900">
            Archive object (provenance gaps)
          </button>
          <button data-preset="photo" type="button" class="rounded-full border border-zinc-200 bg-white px-3 py-1 text-xs text-zinc-700 hover:border-zinc-300 hover:text-zinc-900">
            Contemporary photo (kids label)
          </button>
          <button data-preset="textile" type="button" class="rounded-full border border-zinc-200 bg-white px-3 py-1 text-xs text-zinc-700 hover:border-zinc-300 hover:text-zinc-900">
            Textile piece (material specificity)
          </button>
        </div>
      </div>

      <div class="mt-5 grid gap-4">
        <div class="grid gap-3 sm:grid-cols-2">
          <label class="grid gap-1 text-sm">
            <span class="text-zinc-700">Title (optional)</span>
            <input id="mlg-title" class="rounded-xl border border-zinc-200 px-3 py-2 outline-none focus:border-zinc-400" placeholder="Untitled (Blue Study)" />
          </label>
          <label class="grid gap-1 text-sm">
            <span class="text-zinc-700">Artist (optional)</span>
            <input id="mlg-artist" class="rounded-xl border border-zinc-200 px-3 py-2 outline-none focus:border-zinc-400" placeholder="Unknown" />
          </label>
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          <label class="grid gap-1 text-sm">
            <span class="text-zinc-700">Year (optional)</span>
            <input id="mlg-year" class="rounded-xl border border-zinc-200 px-3 py-2 outline-none focus:border-zinc-400" placeholder="1970s (approx.)" />
          </label>
          <label class="grid gap-1 text-sm">
            <span class="text-zinc-700">Medium / Materials (optional)</span>
            <input id="mlg-medium" class="rounded-xl border border-zinc-200 px-3 py-2 outline-none focus:border-zinc-400" placeholder="Cotton, linen, dye" />
          </label>
        </div>

        <label class="grid gap-1 text-sm">
          <span class="text-zinc-700">Source description (required)</span>
          <textarea id="mlg-description" class="min-h-[160px] rounded-xl border border-zinc-200 px-3 py-2 outline-none focus:border-zinc-400" placeholder="Describe what the visitor sees, any known context, and what you want to emphasize..."></textarea>
          <span class="text-xs text-zinc-500">Minimum: ~30 characters</span>
        </label>

        <div class="flex flex-wrap items-center gap-3">
          <label class="text-sm text-zinc-700">
            Tone
            <select id="mlg-tone" class="ml-2 rounded-xl border border-zinc-200 px-3 py-2 text-sm outline-none focus:border-zinc-400">
              <option value="neutral" selected>neutral</option>
              <option value="warm">warm</option>
              <option value="playful">playful</option>
              <option value="academic">academic</option>
            </select>
          </label>

          <label class="flex items-center gap-2 text-sm text-zinc-700">
            <input id="mlg-stayclose" type="checkbox" class="h-4 w-4" checked />
            Stay close to source text
          </label>
        </div>

        <button
          id="mlg-generate"
          class="mt-2 inline-flex items-center justify-center rounded-2xl bg-zinc-900 px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-zinc-800 disabled:cursor-not-allowed disabled:bg-zinc-200 disabled:text-zinc-500"
          disabled
          type="button"
        >
          Generate labels
        </button>

        <div id="mlg-error" class="hidden rounded-xl border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700"></div>

        <div id="mlg-facilitator" class="mt-2 hidden rounded-xl border border-zinc-200 bg-zinc-50 p-3 text-sm text-zinc-700">
          <div class="font-semibold text-zinc-800">Facilitator notes</div>
          <ol class="mt-2 list-decimal space-y-1 pl-5">
            <li>Choose an example (or paste your own description).</li>
            <li>Generate twice: with <em>Stay close</em> ON, then OFF.</li>
            <li>Compare assumptions, tone, and accessibility. What needs human editing?</li>
          </ol>
        </div>
      </div>
    </section>

    <!-- OUTPUT -->
    <section class="rounded-2xl border border-zinc-200 p-6 shadow-sm">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h2 class="text-lg font-semibold">Output</h2>
          <p class="mt-1 text-sm text-zinc-600">Copy individual sections for drafts and iteration.</p>
        </div>

        <button id="mlg-toggle-details" type="button" class="text-xs font-semibold underline text-zinc-600 hover:text-zinc-900">
          Show prompt & architecture
        </button>
      </div>

      <div id="mlg-empty" class="mt-6 rounded-xl bg-zinc-50 p-4 text-sm text-zinc-600">
        Generate to see wall label drafts, alt text, and curator notes here.
      </div>

      <div id="mlg-loading" class="mt-6 hidden rounded-xl bg-zinc-50 p-4 text-sm text-zinc-600">Working…</div>

      <div id="mlg-output" class="mt-6 hidden space-y-6">
        <div class="space-y-3">
          <div class="flex items-center justify-between gap-4">
            <h3 class="text-sm font-semibold text-zinc-800">Wall label (50–70 words)</h3>
            <button data-copy="wall_label" type="button" class="text-xs font-semibold underline text-zinc-700 hover:text-zinc-900">Copy</button>
          </div>
          <p data-field="wall_label" class="rounded-xl bg-zinc-50 p-3 text-sm leading-6 text-zinc-700 whitespace-pre-wrap"></p>
        </div>

        <div class="space-y-3">
          <div class="flex items-center justify-between gap-4">
            <h3 class="text-sm font-semibold text-zinc-800">Extended label (150–200 words)</h3>
            <button data-copy="extended_label" type="button" class="text-xs font-semibold underline text-zinc-700 hover:text-zinc-900">Copy</button>
          </div>
          <p data-field="extended_label" class="rounded-xl bg-zinc-50 p-3 text-sm leading-6 text-zinc-700 whitespace-pre-wrap"></p>
        </div>

        <div class="space-y-3">
          <div class="flex items-center justify-between gap-4">
            <h3 class="text-sm font-semibold text-zinc-800">Kids label</h3>
            <button data-copy="kids_label" type="button" class="text-xs font-semibold underline text-zinc-700 hover:text-zinc-900">Copy</button>
          </div>
          <p data-field="kids_label" class="rounded-xl bg-zinc-50 p-3 text-sm leading-6 text-zinc-700 whitespace-pre-wrap"></p>
        </div>

        <div class="space-y-3">
          <div class="flex items-center justify-between gap-4">
            <h3 class="text-sm font-semibold text-zinc-800">Audio guide script</h3>
            <button data-copy="audio_guide_script" type="button" class="text-xs font-semibold underline text-zinc-700 hover:text-zinc-900">Copy</button>
          </div>
          <p data-field="audio_guide_script" class="rounded-xl bg-zinc-50 p-3 text-sm leading-6 text-zinc-700 whitespace-pre-wrap"></p>
        </div>

        <div class="space-y-3">
          <div class="flex items-center justify-between gap-4">
            <h3 class="text-sm font-semibold text-zinc-800">Alt text</h3>
            <button data-copy="alt_text" type="button" class="text-xs font-semibold underline text-zinc-700 hover:text-zinc-900">Copy</button>
          </div>
          <p data-field="alt_text" class="rounded-xl bg-zinc-50 p-3 text-sm leading-6 text-zinc-700 whitespace-pre-wrap"></p>
        </div>

        <div>
          <h3 class="text-sm font-semibold text-zinc-800">Curator notes</h3>
          <ul id="mlg-curator-notes" class="mt-2 list-disc space-y-1 pl-5 text-sm text-zinc-700"></ul>
        </div>

        <div>
          <h3 class="text-sm font-semibold text-zinc-800">Variations (alternate wall labels)</h3>
          <div id="mlg-variations" class="mt-2 space-y-3"></div>
        </div>

        <div id="mlg-discussion" class="hidden rounded-2xl border border-zinc-200 p-4">
          <h3 class="text-sm font-semibold text-zinc-800">Discussion prompts</h3>
          <ul class="mt-3 list-disc space-y-1 pl-5 text-sm text-zinc-700">
            <li>What information did the model assume that wasn’t in the source text?</li>
            <li>Which version best respects the artist and audience?</li>
            <li>What would you edit for clarity, accuracy, or cultural context?</li>
            <li>What should never be automated in this workflow?</li>
          </ul>
        </div>
      </div>

      <div id="mlg-details" class="mt-6 hidden rounded-2xl border border-zinc-200 p-4 text-sm">
        <h3 class="font-semibold text-zinc-800">Prompt & architecture</h3>

        <div class="mt-3">
          <div class="text-xs font-semibold text-zinc-700">System prompt</div>
          <pre class="mt-2 whitespace-pre-wrap rounded-xl bg-zinc-50 p-3 text-xs text-zinc-700" id="mlg-system"></pre>
        </div>

        <div class="mt-4">
          <div class="text-xs font-semibold text-zinc-700">User prompt template</div>
          <pre class="mt-2 whitespace-pre-wrap rounded-xl bg-zinc-50 p-3 text-xs text-zinc-700" id="mlg-user"></pre>
        </div>

        <div class="mt-4">
          <div class="text-xs font-semibold text-zinc-700">Architecture</div>
          <pre class="mt-2 whitespace-pre-wrap rounded-xl bg-zinc-50 p-3 text-xs text-zinc-700">
User input → Browser UI
        ↓
Netlify Function (secure)
        ↓
Anthropic API → JSON
        ↓
Render cards + copy tools
          </pre>
        </div>
      </div>
    </section>
  </div>

 <script>
(() => {
  const $ = (id: string) => document.getElementById(id);

  // Elements
  const workshop = $("mlg-workshop") as HTMLInputElement | null;
  const presetsWrap = $("mlg-presets");
  const facilitator = $("mlg-facilitator");
  const discussion = $("mlg-discussion");
  const desc = $("mlg-description") as HTMLTextAreaElement | null;
  const btn = $("mlg-generate") as HTMLButtonElement | null;
  const err = $("mlg-error");

  const empty = $("mlg-empty");
  const loading = $("mlg-loading");
  const output = $("mlg-output");

  const details = $("mlg-details");
  const toggleDetails = $("mlg-toggle-details");

  // Inputs
  const title = $("mlg-title") as HTMLInputElement | null;
  const artist = $("mlg-artist") as HTMLInputElement | null;
  const year = $("mlg-year") as HTMLInputElement | null;
  const medium = $("mlg-medium") as HTMLInputElement | null;
  const tone = $("mlg-tone") as HTMLSelectElement | null;
  const stayClose = $("mlg-stayclose") as HTMLInputElement | null;

  // Prompt display blocks
  const sysBlock = $("mlg-system");
  const userBlock = $("mlg-user");

  const SYSTEM_PROMPT = `You are a museum interpretation assistant. Write clear, accurate interpretive text that respects artists and audiences.
Constraints:
- Do not invent facts. If information is missing, write around it or label as "Unknown".
- Avoid academic jargon unless requested.
- Be culturally sensitive; do not stereotype. Flag sensitive topics with care.
- Keep claims grounded in the provided description.
Return output as valid JSON only.`;

  const USER_TEMPLATE = `Artwork info:
- Title: {{title}}
- Artist: {{artist}}
- Year: {{year}}
- Medium/Materials: {{medium}}
- Description: {{description}}

Preferences:
- Tone: {{tone}}
- Grounding: {{stayCloseToSource}}

Return JSON with:
wall_label, extended_label, kids_label, audio_guide_script, alt_text, curator_notes, variations`;

  if (sysBlock) sysBlock.textContent = SYSTEM_PROMPT;
  if (userBlock) userBlock.textContent = USER_TEMPLATE;

  const presets: Record<string, { title: string; artist: string; year: string; medium: string; description: string }> = {
    abstract: {
      title: "Untitled (Blue Study)",
      artist: "Unknown",
      year: "Unknown",
      medium: "Acrylic on canvas",
      description:
        "A large canvas filled with layered blue forms that shift from sharp edges to soft gradients. Faint scraping and reworking marks are visible across the surface. The composition feels quiet but restless, as if the shapes are moving in and out of focus."
    },
    provenance: {
      title: "Ceremonial Mask",
      artist: "Unknown",
      year: "19th century (approx.)",
      medium: "Wood, pigment, fiber",
      description:
        "A carved mask with geometric patterning and traces of red and black pigment. The museum record notes it entered a private collection in the early 1900s before being donated decades later. Provenance details are incomplete, and the cultural context in the archive is minimal."
    },
    photo: {
      title: "Street Portrait",
      artist: "Unknown",
      year: "2018",
      medium: "Photograph",
      description:
        "A portrait of a person standing in bright sunlight on a city sidewalk. The background is softly blurred while the subject’s clothing and posture read as calm and self-possessed. Strong contrast between light and shadow shapes the mood of the image."
    },
    textile: {
      title: "Study in Thread",
      artist: "Unknown",
      year: "1970s (approx.)",
      medium: "Cotton, linen, dye",
      description:
        "A small textile panel with repeated stitched lines and subtle color shifts from natural fiber tones to muted indigo. The stitching density changes across the surface, creating a rhythm that feels both measured and handmade. The work invites close viewing rather than distance."
    }
  };

  function setPreset(p: { title: string; artist: string; year: string; medium: string; description: string }) {
    if (title) title.value = p.title;
    if (artist) artist.value = p.artist;
    if (year) year.value = p.year;
    if (medium) medium.value = p.medium;
    if (desc) desc.value = p.description;
    validate();
  }

  function validate() {
    if (btn) btn.disabled = (desc?.value || "").trim().length < 30;
  }
  desc?.addEventListener("input", validate);
  validate();

  // Workshop toggles
  workshop?.addEventListener("change", () => {
    const on = workshop.checked;
    presetsWrap?.classList.toggle("hidden", !on);
    facilitator?.classList.toggle("hidden", !on);
    discussion?.classList.toggle("hidden", !on);

    // Auto-open details in workshop mode
    if (on) {
      details?.classList.remove("hidden");
      if (toggleDetails) toggleDetails.textContent = "Hide prompt & architecture";
    }
  });

  // Preset buttons
  presetsWrap?.addEventListener("click", (e) => {
    const b = (e.target as Element).closest("button[data-preset]");
    if (!b) return;
    const key = b.getAttribute("data-preset") || "";
    const p = presets[key];
    if (p) setPreset(p);
  });

  // Prompt/details toggle
  toggleDetails?.addEventListener("click", () => {
    const hidden = details?.classList.contains("hidden") ?? true;
    details?.classList.toggle("hidden", !hidden);
    if (toggleDetails) toggleDetails.textContent = hidden ? "Hide prompt & architecture" : "Show prompt & architecture";
  });

  // Copy handlers
  let lastData: Record<string, string> | null = null;
  document.addEventListener("click", (e) => {
    const copyBtn = (e.target as Element).closest("button[data-copy]");
    if (!copyBtn || !lastData) return;
    const key = copyBtn.getAttribute("data-copy") || "";
    navigator.clipboard.writeText(lastData[key] || "");
  });

  // Generate
  btn?.addEventListener("click", async () => {
    err?.classList.add("hidden");
    empty?.classList.add("hidden");
    output?.classList.add("hidden");
    loading?.classList.remove("hidden");

    try {
      const resp = await fetch("/.netlify/functions/museum-label", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          title: title?.value,
          artist: artist?.value,
          year: year?.value,
          medium: medium?.value,
          description: desc?.value,
          tone: tone?.value,
          stayCloseToSource: stayClose?.checked
        })
      });

      const data = await resp.json();
      if (!resp.ok) throw new Error(data?.error || "Request failed.");

      lastData = data;

      // Fill fields
      document.querySelectorAll("[data-field]").forEach((el) => {
        const key = el.getAttribute("data-field") || "";
        el.textContent = data[key] || "";
      });

      // Curator notes
      const ul = $("mlg-curator-notes");
      if (ul) {
        ul.innerHTML = "";
        (data.curator_notes || []).forEach((n: string) => {
          const li = document.createElement("li");
          li.textContent = n;
          ul.appendChild(li);
        });
      }

      // Variations
      const varWrap = $("mlg-variations");
      if (varWrap) {
        varWrap.innerHTML = "";
        (data.variations || []).forEach((v: string, i: number) => {
          const box = document.createElement("div");
          box.className = "rounded-xl bg-zinc-50 p-3 text-sm text-zinc-700";
          box.innerHTML = `
            <div class="flex items-center justify-between gap-3">
              <span class="font-medium text-zinc-800">Option ${i + 1}</span>
              <button type="button" class="text-xs font-semibold underline text-zinc-700 hover:text-zinc-900">Copy</button>
            </div>
            <p class="mt-2 leading-6 whitespace-pre-wrap"></p>
          `;
          const p = box.querySelector("p");
          if (p) p.textContent = v;
          box.querySelector("button")?.addEventListener("click", () => navigator.clipboard.writeText(v));
          varWrap.appendChild(box);
        });
      }

      loading?.classList.add("hidden");
      output?.classList.remove("hidden");
    } catch (e) {
      loading?.classList.add("hidden");
      empty?.classList.remove("hidden");
      if (err) err.textContent = (e as Error)?.message || "Something went wrong.";
      err?.classList.remove("hidden");
    }
  });
})();
</script>
</SiteLayout>